# Application
APP_NAME=Ránṣẹ́
APP_ENV=development
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=postgresql+asyncpg://ranshe:ranshe_password@db:5432/ranshe_db
POSTGRES_USER=ranshe
POSTGRES_PASSWORD=ranshe_password
POSTGRES_DB=ranshe_db

# Redis
REDIS_URL=redis://redis:6379/0

# Worker
MAX_RETRY_ATTEMPTS=5
RETRY_DELAYS_SECONDS=60,300,1800,7200,28800

# Delivery
DELIVERY_TIMEOUT_SECONDS=30
DELIVERY_USER_AGENT=Ranshe-Webhook/1.0

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
